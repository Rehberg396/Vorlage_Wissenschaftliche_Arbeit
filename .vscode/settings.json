{
  "latex-workshop.latex.autoBuild.run": "never",
  "latex-workshop.latex.recipe.default": "first",
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk-main",
      "command": "latexmk",
      "args": [
        "-r",
        "config/latexmkrc",
        "-pdf",
        "main.tex"
      ]
    },
    {
      "name": "latexmk-stress",
      "command": "latexmk",
      "args": [
        "-r",
        "config/latexmkrc",
        "-pdf",
        "main-stresstest.tex"
      ]
    },
    {
      "name": "latexmk-clear-main",
      "command": "latexmk",
      "args": [
        "-r",
        "config/latexmkrc",
        "-C",
        "main.tex"
      ]
    },
    {
      "name": "latexmk-clear-stress",
      "command": "latexmk",
      "args": [
        "-r",
        "config/latexmkrc",
        "-C",
        "main-stresstest.tex"
      ]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "latex",
      "tools": [
        "latexmk-main"
      ]
    },
    {
      "name": "latex stress",
      "tools": [
        "latexmk-stress"
      ]
    },
    {
      "name": "latex clear",
      "tools": [
        "latexmk-clear-main",
        "latexmk-clear-stress"
      ]
    }
  ]
}
