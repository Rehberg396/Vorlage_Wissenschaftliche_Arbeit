% Signature 
% Use: \signature{Location}
\newcommand{\signature}[1]{
    \newline
    \noindent
    \begin{tabular}{@{}ll@{}}
        #1, den \today & \makebox[6.5cm]{\hrulefill}\\
        & Unterschrift
    \end{tabular}
}

% Definition der Seitenstile
\newcommand{\setupRomanPageStyle}{
    \pagestyle{fancy}
    \fancyhf{} % Clear all header and footer fields
    \fancyhead{} % Disable all header fields
    \fancyfoot[R]{\thepage} % Set right footer with the page number
    \renewcommand{\headrulewidth}{0pt} % No header rule
    \renewcommand{\footrulewidth}{0pt} % No footer rule
    \pagenumbering{Roman} % Set page numbering to Roman numerals
}

\newcommand{\setupArabicPageStyle}{
    \pagestyle{fancy}
    \fancyhf{} % Clear all header and footer fields
    \fancyhead[L]{\leftmark} % Set left header with the chapter title
    \fancyfoot[R]{\thepage} % Set right footer with the page number
    \renewcommand{\headrulewidth}{1pt} % Header rule width
    \renewcommand{\footrulewidth}{0pt} % No footer rule
    \pagenumbering{arabic} % Set page numbering to Arabic numerals
}